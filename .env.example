# ─── Supabase ───────────────────────────────────────────────
# Project URL + anon key (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic (landing analysis + draft generation) ────────
ANTHROPIC_API_KEY=sk-ant-...
# Model IDs (override only if needed)
ANTHROPIC_MODEL_ANALYZE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_DRAFT=claude-sonnet-4-6

# ─── Lemon Squeezy (one-time map unlock) ────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Hosted checkout base, e.g. https://YOUR_STORE.lemonsqueezy.com/checkout/buy
LEMONSQUEEZY_CHECKOUT_URL=

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Daily map limits are set per-plan in lib/billing.ts (free 3 / pro 5).
# Hours to cache an identical URL run before spending new AI calls
URL_CACHE_HOURS=24
# Comma-separated emails allowed into /admin (use your GitHub sign-in email)
ADMIN_EMAILS=
